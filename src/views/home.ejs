<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/images/fourways_logo.svg" type="image/svg+xml">
    <title>
        <%= seo?.title || 'Fourways' %>
    </title>
    <meta name="description" content="<%= seo?.description || 'Small-batch specialty coffee from Fourways.' %>">
    <link rel="canonical" href="<%= seo?.canonicalUrl %>">
    <meta name="robots" content="<%= seo?.robots || 'index,follow' %>">
    <link href="/styles/home.css" rel="stylesheet">
    <link href="/styles/navbar.css" rel="stylesheet">
    <link href="/styles/cart.css" rel="stylesheet">
    <link href="/styles/footer.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Comfortaa:wght@300..700&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <script type="module" src="/scripts/home.js"></script>
    <script type="module" src="/scripts/productCard.js"></script>
</head>

<body class="home-page">
    <%- include('partials/navbar') %>
        <main class="page-wrapper">

            <div class="header__container">
                <!-- <h1 class="headline-text">Fourways Coffee Roasters</h1> -->
                <p>Fourways is a nano-roastery that puts out limited releases and roasts in small batches. Check out our
                    latest
                    releases below:</p>
                <% if (webstoreStatusMessage) { %>
                    <p>
                        <%= webstoreStatusMessage %>
                    </p>
                    <% } %>
            </div>


            <% if (!isWebstoreInMaintenance) { %>
                <!-- Cart Drawer -->
                <%- include('cart') %>
                    <%- include('partials/grind-modal') %>

                        <!-- Cart Overlay -->
                        <div id="cart-overlay" class="cart-overlay"></div>
                        <% } %>
        </main>
        <%- include('partials/footer') %>

</body>

</html>