<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/images/fourways_logo.svg" type="image/svg+xml">
    <title>
        <%= seo?.title || 'Maintenance - Fourways' %>
    </title>
    <meta name="description"
        content="<%= seo?.description || 'Temporary maintenance updates for Fourways webstore.' %>">
    <link rel="canonical" href="<%= seo?.canonicalUrl %>">
    <meta name="robots" content="<%= seo?.robots || 'noindex,nofollow' %>">
    <link href="/styles/home.css" rel="stylesheet">
    <link href="/styles/navbar.css" rel="stylesheet">
    <link href="/styles/footer.css" rel="stylesheet">
    <script type="module" src="/scripts/home.js" defer></script>
</head>

<body>
    <%- include('partials/navbar') %>
        <main class="page-wrapper">
            <section class="header__container">
                <h1 class="headline-text">Webstore under maintenance</h1>
                <p>Purchasing is temporarily unavailable while we complete maintenance. Please check back soon.</p>
            </section>
        </main>
        <%- include('partials/footer') %>
</body>

</html>